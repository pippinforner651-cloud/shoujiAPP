{
  "name": "e23-backend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "test": "node scripts/vitest-run.mjs integration",
    "test:integration": "node scripts/vitest-run.mjs integration",
    "test:embedded": "node scripts/vitest-run.mjs embedded",
    "test:ci": "node scripts/vitest-run.mjs ci",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "embedded-postgres": "^17.10.0-beta.17",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.8"
  }
}
