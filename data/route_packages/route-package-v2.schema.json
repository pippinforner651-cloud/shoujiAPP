{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://e23running.local/schemas/route-package-v2.json",
  "title": "E23 Route Package V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "status",
    "scope",
    "distancePolicy",
    "declaredDistanceMeters",
    "startPlace",
    "endPlace",
    "nodes",
    "segments",
    "provenance"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["DRAFT", "VERIFIED", "PUBLISHED", "ARCHIVED"] },
    "scope": { "enum": ["CHINA", "WORLD", "CUSTOM"] },
    "distancePolicy": { "const": "REAL_1_TO_1" },
    "declaredDistanceMeters": { "type": "integer", "minimum": 27000000 },
    "startPlace": { "$ref": "#/$defs/place" },
    "endPlace": { "$ref": "#/$defs/place" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "segments": {
      "type": "array",
      "items": { "$ref": "#/$defs/segment" }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "auditNote": { "type": "string" }
  },
  "$defs": {
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "latitude", "longitude"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "name", "latitude", "longitude", "cumulativeDistanceMeters"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "cumulativeDistanceMeters": { "type": "integer", "minimum": 0 }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "fromNodeId", "toNodeId", "distanceMeters", "kind", "roadNames", "geometry", "sourceRefs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 1 },
        "fromNodeId": { "type": "string", "minLength": 1 },
        "toNodeId": { "type": "string", "minLength": 1 },
        "distanceMeters": { "type": "integer", "exclusiveMinimum": 0 },
        "kind": { "enum": ["ROAD", "FERRY"] },
        "roadNames": { "type": "array", "items": { "type": "string" } },
        "geometry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "coordinates"],
          "properties": {
            "type": { "const": "LineString" },
            "coordinates": {
              "type": "array",
              "items": {
                "type": "array",
                "prefixItems": [
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 }
                ],
                "items": false,
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        },
        "sourceRefs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurementMethod", "sources", "auditedAt"],
      "properties": {
        "measurementMethod": { "type": "string", "minLength": 1 },
        "sources": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "auditedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  }
}
