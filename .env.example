# E23跑起来 · 环境变量模板（复制为 .env 后按需修改；不得提交真实密钥）

# 个人年度参考目标（公里）
VITE_ANNUAL_GOAL_KM=270

# 多人后端是否上线（true/false）。上线前保持 false：不显示任何班级人数/里程/排行
VITE_MULTIPLAYER_ENABLED=false

# 测试登录验证码（测试用途，非真实短信；正式上线前必须关闭测试入口）
VITE_TEST_SMS_CODE=123456

# 地图服务提供方（static-pack=内置静态路线包；预留 amap=高德）
VITE_MAP_PROVIDER=static-pack
